# DevOps 运维平台 - 环境变量配置
# 复制此文件为 .env 并按需修改

# ========== Web UI 端口 ==========
FRONTEND_PORT=8080

# ========== 数据库端口（宿主机暴露端口） ==========
MYSQL_PORT=3306
REDIS_PORT=6379

# ========== 数据库配置 ==========
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=devops
MYSQL_USER=devops
MYSQL_PASSWORD=devops123
REDIS_PASSWORD=redis123

# ========== 后端配置（DEVOPS_ 前缀会映射到 config key） ==========
DEVOPS_SERVER_PORT=8000
DEVOPS_SERVER_MODE=debug
DEVOPS_SERVER_ENABLE_SWAGGER=true

DEVOPS_DB_HOST=mysql
DEVOPS_DB_PORT=3306
DEVOPS_DB_USERNAME=devops
DEVOPS_DB_PASSWORD=devops123
DEVOPS_DB_DB=devops

DEVOPS_REDIS_ADDR=redis:6379
DEVOPS_REDIS_PASSWORD=redis123

DEVOPS_SESSION_EXPIRE=7200
DEVOPS_CRYPTO_SECRET=change-me-to-a-random-32-char-string
